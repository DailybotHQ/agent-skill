# But do NOT ignore the `env` Dailybot sub-skill directory — the `env/`
# rule above is meant to catch Python virtualenvs, not our shipped skill.
!skills/dailybot/env/
!skills/dailybot/env/**

# Node (some contributors may run `npx skills` locally for testing)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
.pnp.*

# Bats / shellcheck artifacts
.bats-cache/

# Local environment overrides
.env
.env.local
.env.*.local
.envrc

# Test / coverage outputs
coverage/
.coverage
*.cov
*.log

# Built / packaged artifacts (we have none today — defensive)
dist/
build/
out/

# Repo `tmp/` for scratch work (see AGENTS.md "Temporary Files")
# Ignore everything inside; keep only `.gitkeep` so the directory is tracked.
tmp/*
!tmp/.gitkeep

# Local-only Dailybot runtime state can drop into `.dailybot/` during
# `dailybot login`, `dailybot hook ...` invocations, etc. Ignore the
# directory's contents broadly so that scratch state does not get
# committed, but **track `.dailybot/profile.json`** — that file is the
# repo's committed identity pin (per
# `skills/dailybot/shared/repo-profile.md`) and MUST be visible to every
# contributor and every agent.
#
# NOTE: the glob `/.dailybot/*` (rather than `/.dailybot/`) is required
# for the `!` exception below to take effect. Per git's gitignore docs:
# "It is not possible to re-include a file if a parent directory of
# that file is excluded." `/.dailybot/*` excludes the *contents* one
# file at a time; `/.dailybot/` would exclude the directory itself and
# short-circuit any inclusion attempt.
/.dailybot/*
!/.dailybot/profile.json


# VS Code workspace settings: personal `.vscode/` (and `.vscode_*` variants
# contributors might create) stay out of the repo, but `.vscode_example/` is
# tracked as a shared template — contributors copy it to `.vscode/` if they
# want the Dailybot recommended workspace setup.
.vscode/
.vscode_*/
!.vscode_example/
